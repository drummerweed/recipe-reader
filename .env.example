# Database Path (Local SQLite)
# Example: "/app/data/recipes.db" (for Docker) or "./recipes.db" (local)
DATABASE_PATH="/app/data/recipes.db"

# Optional: Scraper Headers (to bypass basic bot detection)
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"

# Optional: Server Port
BACKEND_PORT=5000
FRONTEND_PORT=8080
